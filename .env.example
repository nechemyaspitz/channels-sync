# Vimeo API
VIMEO_ACCESS_TOKEN=your_vimeo_personal_access_token
VIMEO_USER_ID=me

# Webflow API
WEBFLOW_API_TOKEN=your_webflow_api_token
WEBFLOW_SITE_ID=your_webflow_site_id
WEBFLOW_VIDEOS_COLLECTION_ID=your_videos_collection_id
WEBFLOW_CATEGORIES_COLLECTION_ID=your_categories_collection_id

# Webhook verification
WEBHOOK_SECRET=your_webhook_secret_here

# Admin dashboard password (optional — leave empty for no auth)
ADMIN_PASSWORD=your_admin_password
